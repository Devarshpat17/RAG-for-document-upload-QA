# Django Settings
SECRET_KEY=django-insecure-change-this-in-production-1234567890
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite by default, can switch to PostgreSQL)
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# LLM Configuration
# Recommended models:
# - mistralai/Mistral-7B-Instruct-v0.2 (best quality, slower)
# - microsoft/phi-2 (good balance)
# - gpt2 (fastest, for testing)
LLM_MODEL=gpt2
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MAX_TOKENS=512
TEMPERATURE=0.7

# FAISS Configuration
FAISS_INDEX_TYPE=Flat  # Options: Flat, IVFFlat, HNSW
SIMILARITY_TOP_K=5

# Document Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_FILE_SIZE_MB=10

# Paths
MEDIA_ROOT=media
FAISS_INDEX_DIR=faiss_indices
